# voice-macro — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env (já está no .gitignore).

# Chave de API do OpenRouter — necessária para os modos LLM (CLEAN, SUMMARY, INSTRUCT, REFINE, ACTION)
# Obtenha em: https://openrouter.ai/keys
# Sem esta chave, somente o modo DICTATE estará disponível.
OPENROUTER_API_KEY=sk-or-...
